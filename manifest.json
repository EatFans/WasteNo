{
  "manifest_version": 3,
  "name": "WasteNo",
  "version": "1.0.0",
  "description": "别水了",

  "action": {
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background/index.js"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ]
}